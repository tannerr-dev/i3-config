# i3 config file (v4)
## complete starter file and more commented out below
set $mod Mod4
font pango:Ubuntu Mono 9
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork --color=3f3131
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
floating_modifier $mod
tiling_drag modifier titlebar
exec --no-startup-id feh --bg-scale $HOME/tamanrassetAlgeria.jpeg

#custom mouse / trackpad settings
exec xinput set-prop "Elan Touchpad" "libinput Tapping Enabled" 1
# do these work?
# exec xinput set-prop "Elan Trackpoint" "libinput Tapping Enabled" 1
# exec xinput set-prop 9 317 1
# exec xinput set-prop 10 190 1, 0, 0, 0, 1, 0, 0, 0, 2

# set $c1 "#a03b24"
# set $c1 "#E9B44C"
# set $c1 "#AA663Bl"
# set $c1 "#352020"
set $c1 "#986F4B"

# class                   border    backgr.    text     indicator   child_border
client.focused            $c1       $c1     #ffffff   $c1         $c1 
# client.focused          #4c7899 #285577 #ffffff #2e9ef4   #285577
# client.focused          #333333 #333333 #999999 #292d2e   #222222
client.unfocused        #333333 #222222 #888888 #292d2e   #222222
client.focused_inactive #333333 #222222 #888888 #292d2e   #222222
client.urgent           #2f343a #900000 #ffffff #900000   #900000
client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c
client.background       #ffffff

set $b 4
default_border pixel $b
default_floating_border pixel $b
for_window [class="ghostty"] border pixel $b
for_window [class="Brave-browser"] border pixel $b
for_window [class="Brave-browser"] border pixel $b
for_window [class="Waterfox"] border pixel $b
for_window [class="Firefox"] border pixel $b
for_window [class="nemo"] border pixel $b
for_window [class="Files"] border pixel $b

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

bindsym $mod+t exec ghostty
bindsym $mod+b exec brave-browser 
bindsym $mod+w exec $HOME/.local/opt/waterfox/waterfox
bindsym $mod+f exec GTK_THEME=Adwaita-dark nemo
bindsym $mod+s exec import $HOME/stuff/screenshot.jpeg
bindsym $mod+Escape exec systemctl suspend
bindsym $mod+d exec "rofi -modi drun,run -show drun" 
bindsym $mod+Shift+q kill

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+m fullscreen toggle
bindsym $mod+g layout stacking
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"

bindsym Mod1+Control+a workspace number $ws1
bindsym Mod1+Control+s workspace number $ws2
bindsym Mod1+Control+d workspace number $ws3
bindsym Mod1+Control+f workspace number $ws4
bindsym Mod1+Control+g workspace number $ws5

bindsym Mod1+Shift+a move container to workspace number $ws1
bindsym Mod1+Shift+s move container to workspace number $ws2
bindsym Mod1+Shift+d move container to workspace number $ws3
bindsym Mod1+Shift+f move container to workspace number $ws4
bindsym Mod1+Shift+g move container to workspace number $ws5

bindsym $mod+r mode "resize"
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}


bar {
        status_command i3status --config ~/.config/i3/i3status.conf
        mode invisible
        colors{
            background #000000
            statusline #ffe19b
            separator #666666

            focused_workspace  #ffe19b #FFD46F #48402C
            active_workspace   #333333 #5f676a #ffffff
            inactive_workspace #333333 #222222 #888888
            urgent_workspace   #2f343a #900000 #ffffff
            binding_mode       #2f343a #900000 #ffffff
        }
}
